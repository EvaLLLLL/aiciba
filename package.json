{
  "name": "aiciba",
  "version": "1.0.5",
  "description": "A CLI English-Chinese dictionary powered by AI",
  "bin": {
    "ciba": "dist/main.js"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsup",
    "start": "node dist/main.js",
    "lint": "tsc --noEmit",
    "postinstall": "node dist/postinstall.js",
    "prepublishOnly": "pnpm lint && pnpm build"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "cli",
    "dictionary",
    "ai",
    "english",
    "chinese"
  ],
  "author": "Yuhao Liu",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@clack/prompts": "^1.1.0",
    "ai": "^6.0.116",
    "chalk": "^5.6.2",
    "dotenv": "^16.5.0",
    "zod": "^4.3.6"
  }
}
